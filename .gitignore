# Dependencies
backend/node_modules/
buyer-app/node_modules/
seller-app/node_modules/

@"
node_modules/
*/node_modules/
.env
uploads/
"@ | Add-Content .gitignore

# Monorepo app env files
backend/.env
backend/.env.*
!backend/.env.example

buyer-app/.env
buyer-app/.env.*
!buyer-app/.env.example

seller-app/.env
seller-app/.env.*
!seller-app/.env.example

# Runtime uploads and generated assets
uploads/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
